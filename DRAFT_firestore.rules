rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidTrendingProduct(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'sourceCountry', 'trendScore', 'status', 'createdAt', 'ownerId'])
        && data.title is string && data.title.size() <= 200
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.sourceCountry is string && data.sourceCountry.size() <= 100
        && data.trendScore is number
        && data.status in ['pending_review', 'approved', 'synced_to_shopify', 'campaign_live', 'rejected']
        && data.createdAt is timestamp
        && data.ownerId == request.auth.uid;
    }

    match /trending_products/{productId} {
      allow create: if isSignedIn() 
        && isValidTrendingProduct(incoming())
        && productId.size() <= 128;
      
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      
      allow update: if isSignedIn() 
        && isValidTrendingProduct(incoming())
        && incoming().ownerId == existing().ownerId
        && (
          // Action: Review/Evaluate
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'optimizedTitle', 'optimizedDescription', 'tags'])) ||
          // Action: Sync
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'shopifyUrl'])) ||
          // Action: Launch Campaign
          (incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        );

      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
