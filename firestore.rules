rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == "collinskp.ai@gmail.com"; 
    }

    function isValidTrendingProduct(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'sourceCountry', 'trendScore', 'status', 'createdAt', 'ownerId'])
        && data.title is string && data.title.size() <= 200
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.sourceCountry is string && data.sourceCountry.size() <= 100
        && data.trendScore is number
        && data.status in ['pending_review', 'approved', 'synced_to_shopify', 'campaign_live', 'rejected']
        && (data.createdAt is timestamp || data.createdAt is string) 
        && (data.ownerId == request.auth.uid || data.ownerId == "system");
    }

    match /trending_products/{productId} {
      allow create: if (isSignedIn() && isValidTrendingProduct(incoming())) || isAdmin();
      
      allow get: if isAdmin() || (isSignedIn() && (existing().ownerId == request.auth.uid || existing().ownerId == "system"));
      allow list: if isAdmin() || (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.ownerId == "system"));
      
      allow update: if isAdmin() || (isSignedIn() 
        && isValidTrendingProduct(incoming())
        && incoming().ownerId == existing().ownerId);

      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }
  }
}
